   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "from sklearn.preprocessing import PolynomialFeatures, StandardScaler\n",
    "from sklearn.datasets import make_regression"
   ],
   "outputs": [],
   "execution_count": 701
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "UaGGtXfynzDl",
    "ExecuteTime": {
     "end_time": "2026-03-01T15:09:50.601671700Z",
     "start_time": "2026-03-01T15:09:50.556915867Z"
    }
   },
   "source": [
    "# Генерация данных\n",
    "np.random.seed(42)\n",
    "X = np.sort(np.random.rand(200, 1) * 6 - 3, axis=0)\n",
    "# Нелинейная зависимость: y = 0.5*x^3 - x^2 + 2*x + шум\n",
    "y = 0.5 * X**3 - X**2 + 2 * X + np.random.normal(0, 2, size=(200, 1))"
   ],
   "outputs": [],
   "execution_count": 702
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "U37Xag1Bn6Jv",
    "ExecuteTime": {
     "end_time": "2026-03-01T15:09:50.647881466Z",
     "start_time": "2026-03-01T15:09:50.602266187Z"
    }
   },
   "source": [
    "# Подготовка признаков (Полином 3-й степени)\n",
    "poly = PolynomialFeatures(degree=3, include_bias=False)\n",
    "X_poly = poly.fit_transform(X)\n",
    "\n",
    "# Масштабирование (Критически важно для стабильности градиентов)\n",
    "scaler = StandardScaler()\n",
    "X_poly_scaled = scaler.fit_transform(X_poly)\n",
    "\n",
    "# Конвертация в тензоры PyTorch\n",
    "X_tensor = torch.tensor(X_poly_scaled, dtype=torch.float32)\n",
    "y_tensor = torch.tensor(y, dtype=torch.float32)"
   ],
   "outputs": [],
   "execution_count": 703
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "JdYdvmWon96B",
    "ExecuteTime": {
     "end_time": "2026-03-01T15:09:50.694500887Z",
     "start_time": "2026-03-01T15:09:50.648592069Z"
    }
   },
   "source": [
    "# Обучение\n",
    "def train_model(optimizer_class, lr=0.1, epochs=200):\n",
    "    # Модель: Линейный слой (вход 3 признака: x, x^2, x^3)\n",
    "    model = nn.Linear(3, 1)\n",
    "    # Инициализируем оптимизатор\n",
    "    optimizer = optimizer_class(model.parameters(), lr=lr)\n",
    "    criterion = nn.MSELoss()\n",
    "\n",
    "    loss_history = []\n",
    "\n",
    "    for epoch in range(epochs):\n",
    "        # Прямой проход\n",
    "        y_pred = model(X_tensor)\n",
    "        loss = criterion(y_pred, y_tensor)\n",
    "\n",
    "        # Обратный проход и оптимизация\n",
    "        optimizer.zero_grad() # Обнуляем градиенты с прошлого шага\n",
    "        loss.backward()       # Считаем градиенты\n",
    "        optimizer.step()      # Обновляем веса\n",
    "\n",
    "        loss_history.append(loss.item())\n",
    "\n",
    "    return model, loss_history"
   ],
   "outputs": [],
   "execution_count": 704
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "XqthhjUQoCXA",
    "ExecuteTime": {
     "end_time": "2026-03-01T15:09:50.776865066Z",
     "start_time": "2026-03-01T15:09:50.694851184Z"
    }
   },
   "source": [
    "# Vanilla SGD (в PyTorch это SGD без моментума)\n",
    "model_sgd, hist_sgd = train_model(torch.optim.SGD, lr=0.01)\n",
    "# RMSProp\n",
    "model_rmsprop, hist_rmsprop = train_model(torch.optim.RMSprop, lr=0.01)\n",
    "# Adam\n",
    "model_adam, hist_adam = train_model(torch.optim.Adam, lr=0.1)"
   ],
   "outputs": [],
   "execution_count": 705
  },
