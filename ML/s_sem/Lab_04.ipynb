   },
   "source": [
    "# Создание модели с регуляризацией\n",
    "# L2-регуляризация в PyTorch задается параметром weight_decay в оптимизаторе\n",
    "model = nn.Linear(X_train.shape[1], 1)\n",
    "optimizer = torch.optim.Adam(model.parameters(), lr=0.01, weight_decay=0.01) # weight_decay = L2\n",
    "criterion = nn.MSELoss()"
   ],
   "outputs": [],
   "execution_count": 716
  },
  {
   "cell_type": "code",
   "metadata": {
    "id": "rFiQ-oI8qmMf",
